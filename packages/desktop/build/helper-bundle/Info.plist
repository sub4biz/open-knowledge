<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
    Helper bundle Info.plist for `OpenKnowledge Server.app`, the detached-
    server helper bundle inside `OpenKnowledge.app/Contents/Frameworks/`.

    `CFBundleExecutable` MUST stay byte-for-byte `OpenKnowledge Helper` —
    matches Electron's canonical generic-helper basename. The helper stub
    cloned into this bundle by `scripts/afterPack.mjs` inspects its own
    `_NSGetExecutablePath()` basename early in boot and silently SIGTRAPs
    (exit 133, empty stderr) for any other name, including descriptive
    choices ("OpenKnowledge Server") or invented suffixes ("Helper
    (Server)") not in Electron's hardcoded {generic, Renderer, GPU,
    Plugin} type set. The bundle directory name (`OpenKnowledge
    Server.app`) is free to be descriptive — only the executable
    basename is load-bearing. Runtime guard:
    `tests/integration/packaged-helper-runs-as-node.test.ts`.

    `LSUIElement=true` is the Dock-suppression key that PR #1290 was
    written to introduce — without it, LaunchServices keys on the spawn
    binary path and pins a stuck "exec" Dock placeholder for the lifetime
    of the detached server.

    `LSEnvironment.MallocNanoZone=0` and `NSSupportsAutomaticGraphicsSwitching`
    mirror the keys Electron ships in its own helper Info.plists. They are
    NOT load-bearing for the SIGTRAP fix (verified empirically — the trap
    persisted with these set when the executable basename was wrong), but
    they bring this bundle structurally closer to the sibling Helper
    bundles for forward compatibility.
-->
<plist version="1.0">
<dict>
    <key>CFBundleIdentifier</key>
    <string>com.inkeep.open-knowledge.server</string>
    <key>CFBundleName</key>
    <string>OpenKnowledge Server</string>
    <key>CFBundleDisplayName</key>
    <string>OpenKnowledge Server</string>
    <key>CFBundleExecutable</key>
    <string>OpenKnowledge Helper</string>
    <key>CFBundlePackageType</key>
    <string>APPL</string>
    <key>CFBundleVersion</key>
    <string>1.0.0</string>
    <key>CFBundleShortVersionString</key>
    <string>1.0.0</string>
    <key>LSEnvironment</key>
    <dict>
      <key>MallocNanoZone</key>
      <string>0</string>
    </dict>
    <key>LSUIElement</key>
    <true/>
    <key>NSSupportsAutomaticGraphicsSwitching</key>
    <true/>
</dict>
</plist>
